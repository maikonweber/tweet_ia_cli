# OpenRouter (geração de texto)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=280

# Opcional: força um modelo no topo da cascata
# OPENROUTER_MODEL=openrouter/free

# Opcional: listas custom (vírgula)
# OPENROUTER_FREE_MODELS=openrouter/free,meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_PAID_FALLBACK_MODELS=inclusionai/ling-2.6-flash,meta-llama/llama-3.1-8b-instruct

# OPENROUTER_SKIP_FREE=true
# OPENROUTER_VERBOSE=true

# Playwright
X_HEADLESS=false
