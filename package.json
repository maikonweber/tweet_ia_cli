{
  "name": "tweet-ia-cli",
  "version": "1.1.0",
  "description": "CLI pessoal: gera tweets com OpenRouter e publica no X via Playwright",
  "type": "module",
  "bin": {
    "tweet": "./bin/tweet.js"
  },
  "scripts": {
    "tweet": "node ./bin/tweet.js",
    "post": "node ./bin/tweet.js post",
    "generate": "node ./bin/tweet.js generate",
    "login": "node ./bin/tweet.js login",
    "link:global": "npm link",
    "unlink:global": "npm unlink -g tweet-ia-cli",
    "postinstall": "npx playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "playwright": "^1.61.1"
  }
}
